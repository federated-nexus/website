---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro"
import "../../styles/page.css"
---

<StarlightPage
    frontmatter={{ title: "Реєстрація в Federated Nexus", template: "splash" }}
>
    <form method="post" action="https://register.federated.nexus">
        <label>
            Ім'я користувача (тільки буквено-цифрові символи, без пробілів)
            <input
                name="username"
                type="text"
                required
                pattern="^[A-Za-z0-9]+$"
            />
        </label>

        <div class="honeypot">
            <input
                type="text"
                name="honeypot"
                tabindex="-1"
                autocomplete="off"
            />
        </div>

        <label>
            E-mail
            <input name="email" type="email" required />
        </label>

        <label class="checkbox">
            <input name="code" type="checkbox" value="yes" required />
            Я ознайомився(лась) з <a href="../code/">Кодексом поведінки</a> та погоджуюся з його умовами.
        </label>

        <label class="checkbox">
            <input name="policy" type="checkbox" value="yes" required />
            Я ознайомився(лась) з <a href="../privacy-policy/"
                >Політикою конфіденційності</a
            > та погоджуюся з її умовами.
        </label>

        <button type="submit"><span>Надіслати</span></button>
    </form>
</StarlightPage>
