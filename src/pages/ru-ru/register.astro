---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro"
import "../../styles/page.css"
---

<StarlightPage
    frontmatter={{ title: "Регистрация в Federated Nexus", template: "splash" }}
>
    <form method="post" action="https://register.federated.nexus">
        <label>
            Имя пользователя (только буквы и цифры, без пробелов)
            <input
                name="username"
                type="text"
                required
                pattern="^[A-Za-z0-9]+$"
            />
        </label>

        <div class="honeypot">
            <input
                type="text"
                name="honeypot"
                tabindex="-1"
                autocomplete="off"
            />
        </div>

        <label>
            E-mail
            <input name="email" type="email" required />
        </label>

        <label class="checkbox">
            <input name="code" type="checkbox" value="yes" required />
            Я ознакомился(лась) с <a href="../code/">Кодексом поведения</a> и согласен(на) с его положениями.
        </label>

        <label class="checkbox">
            <input name="policy" type="checkbox" value="yes" required />
            Я ознакомился(лась) с <a href="../privacy-policy/"
                >Политикой конфиденциальности</a> и согласен(на) с её положениями.
        </label>

        <button type="submit"><span>Отправить</span></button>
    </form>
</StarlightPage>
